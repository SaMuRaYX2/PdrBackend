## Ignore Visual Studio / Rider temporary files, build results, and
## files generated by popular Visual Studio add-ins.

/traffic-rules-client
/GreenWayScraper

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# SQLite Database (very important not to push the local DB!)
*.db
*.db-shm
*.db-wal
app.db

# Visual Studio / Rider local folders
.vs/
.idea/
*.iws
*.iml
*.ipr

# Secrets and environment variables
.env
.env.*
appsettings.Development.json
appsettings.Local.json

# Mac OS
.DS_Store

# Logs
*.log
